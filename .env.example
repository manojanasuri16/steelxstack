# Admin login password (change this!)
ADMIN_PASSWORD=your-secure-password-here

# Secret used to sign JWT tokens (change this!)
ADMIN_SECRET=your-random-secret-here

# Upstash Redis (get from https://upstash.com - free tier)
# Without these, data is stored in a local JSON file (dev only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
