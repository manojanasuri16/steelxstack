# Admin login password (change this!)
ADMIN_PASSWORD=your-secure-password-here

# Secret used to sign JWT tokens (change this!)
ADMIN_SECRET=your-random-secret-here

# Upstash Redis (get from https://upstash.com - free tier)
# Without these, data is stored in a local JSON file (dev only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob (for image uploads in production)
# Add a Blob store in Vercel dashboard → Storage → Create → Blob
# The token is auto-added to your env vars
BLOB_READ_WRITE_TOKEN=

# Strava API (for activity feed)
# Create app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
